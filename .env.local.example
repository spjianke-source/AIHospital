# =============================================================================
# AI Hospital – Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your own values.
# .env.local is listed in .gitignore and will NOT be committed to Git.
# =============================================================================


# -----------------------------------------------------------------------------
# Convex Backend (Required)
# -----------------------------------------------------------------------------
# If using Convex Cloud (https://convex.dev), set only VITE_CONVEX_URL.
# If self-hosting Convex, set all three variables below.

VITE_CONVEX_URL=https://<your-deployment>.convex.cloud

# Self-hosted Convex only:
# CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
# CONVEX_SELF_HOSTED_ADMIN_KEY="convex-self-hosted|<your-admin-key>"


# -----------------------------------------------------------------------------
# Ollama (Required for embeddings; also used as default chat LLM)
# -----------------------------------------------------------------------------
# Ollama must be running locally or on a reachable host.
# Default embedding model: mxbai-embed-large  (dimension: 1024)
# Default chat model:      llama3

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
# OLLAMA_EMBEDDING_MODEL=mxbai-embed-large   # Optional, defaults to mxbai-embed-large


# -----------------------------------------------------------------------------
# DeepSeek API (Optional – required only when DeepSeek mode is selected in UI)
# -----------------------------------------------------------------------------
# Get your key at: https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Qwen / Alibaba Cloud API (Optional – required only when Qwen mode is selected)
# -----------------------------------------------------------------------------
# Get your key at: https://dashscope.aliyuncs.com
# QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Debug / Development (Optional)
# -----------------------------------------------------------------------------
# Set to any non-empty value to show the debug UI overlay in the browser.
# VITE_SHOW_DEBUG_UI=true
